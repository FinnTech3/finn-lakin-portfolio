# ============================================================
#  Portfolio — .gitignore
#  Anything secret, large, or build-only goes here.
# ============================================================

# Secrets & local config
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
config.local.*

# OS noise
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.bak
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artefacts
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/

# Dependency directories
node_modules/
bower_components/
vendor/
__pycache__/
*.pyc
.venv/
venv/
env/

# Internal / development artefacts that should never be public
.superpowers/
for-claude-design.html
claude-design-brief.html
docs/superpowers/
assets/_generate_*.py
_dev/v1-backup/
_dev/claude-design-brief.html
_dev/for-claude-design.html

# Python build cache
*.egg-info/
*.egg

# Coverage / test artefacts
coverage/
.coverage
.pytest_cache/
.mypy_cache/

# OS-level temp & swap files
*.tmp
*.temp

# Local Netlify folder
.netlify
