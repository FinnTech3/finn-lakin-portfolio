# Copy to `.env` and fill in.  `.env` is gitignored — never commit real keys.

# Anthropic — used by the regime detector
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Alpaca — PAPER endpoint only.  The framework refuses non-paper URLs.
ALPACA_PAPER_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_PAPER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# News / macro feeds (optional — falls back to free public sources if absent)
FRED_API_KEY=xxxxxxxxxxxxxxxx
